        "workspace": "/Users/chenxiangli/.openclaw/workspace-reddit",
        "model": "bailian/glm-5",
        "skills": [
          "tavily",
          "web_search",
          "web_fetch",
          "baoyu-post-to-x"
        ],
        "tools": {
          "profile": "full"
        }
      },
      {
        "id": "tiktok-director",
        "name": "TikTok 爆款编导",
        "workspace": "/Users/chenxiangli/.openclaw/workspace-tiktok",
        "model": "bailian/qwen3.5-plus",
        "skills": [
          "nano-banana-pro",
          "baoyu-danger-gemini-web",
