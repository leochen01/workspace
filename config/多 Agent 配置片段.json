  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "lead",
        "voc-analyst",
        "geo-optimizer",
        "reddit-spec",
        "tiktok-director"
      ]
    }
  },
  
  "bindings": [
    {
      "agentId": "lead",
      "match": {
        "channel": "feishu",
        "accountId": "lead"
      }
    },
    {
      "agentId": "voc-analyst",
      "match": {
        "channel": "feishu",
        "accountId": "voc"
      }
    },
    {
      "agentId": "geo-optimizer",
      "match": {
        "channel": "feishu",
        "accountId": "geo"
      }
    },
    {
      "agentId": "reddit-spec",
      "match": {
        "channel": "feishu",
        "accountId": "reddit"
      }
    },
    {
      "agentId": "tiktok-director",
      "match": {
        "channel": "feishu",
        "accountId": "tiktok"
      }
    }
  ],
  
  "channels": {
    "feishu": {
      "enabled": true,
      "connectionMode": "websocket",
      "dmPolicy": "open",
      "accounts": {
        "lead": {
          "appId": "cli_xxx_lead",
          "appSecret": "xxx_lead"
        },
        "voc": {
          "appId": "cli_xxx_voc",
          "appSecret": "xxx_voc"
        },
        "geo": {
          "appId": "cli_xxx_geo",
          "appSecret": "xxx_geo"
        },
        "reddit": {
          "appId": "cli_xxx_reddit",
          "appSecret": "xxx_reddit"
        },
        "tiktok": {
          "appId": "cli_xxx_tiktok",
          "appSecret": "xxx_tiktok"
        }
      }
    }
  }
}
